<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="xX8XGSDFbYsbYe2ywiWX">
    <mxGraphModel dx="1030" dy="570" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\n&#39; Title\ntitle Entity-Relationship Diagram (ERD)\n\n&#39; Define entity styles\nentity \&quot;Users\&quot; as users {\n    * user_id : PK\n    --\n    name\n    email\n    phone\n    password\n    date_of_birth\n    created_at\n}\n\nentity \&quot;Appointments\&quot; as appointments {\n    * appointment_id : PK\n    --\n    user_id : FK\n    appointment_date\n    appointment_time\n    doctor_name\n    location\n    status\n    notes\n}\n\nentity \&quot;Reminders\&quot; as reminders {\n    * reminder_id : PK\n    --\n    appointment_id : FK\n    reminder_time\n    reminder_type\n    is_sent\n    created_at\n}\n\nentity \&quot;HealthContent\&quot; as healthcontent {\n    * content_id : PK\n    --\n    title\n    content_type\n    description\n    url\n    created_at\n}\n\nentity \&quot;MedicalRecords\&quot; as medicalrecords {\n    * record_id : PK\n    --\n    user_id : FK\n    record_date\n    diagnosis\n    prescription\n    doctor_notes\n    attachments\n    created_at\n}\n\nentity \&quot;Messages\&quot; as messages {\n    * message_id : PK\n    --\n    sender_id : FK\n    receiver_id : FK\n    message_text\n    sent_at\n    is_read\n}\n\n&#39; Relationships\nusers ||--o{ appointments : \&quot;has\&quot;\nusers ||--o{ medicalrecords : \&quot;has\&quot;\nusers }o--o{ messages : \&quot;sends/receives\&quot;\n\nappointments ||--|| reminders : \&quot;has\&quot;\n\n&#39; Notes for foreign keys\nnote right of appointments : Foreign Key: user_id references Users(user_id)\nnote right of medicalrecords : Foreign Key: user_id references Users(user_id)\nnote right of messages : Foreign Keys: sender_id, receiver_id\\nreference Users(user_id)\nnote right of reminders : Foreign Key: appointment_id\\nreferences Appointments(appointment_id)\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="qjZdGXRdEMkuwhH5NXJk-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="658" width="1505" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
